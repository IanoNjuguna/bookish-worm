# This file contains example environment variables.
# Copy this file to .env.local and fill in your actual values.
# Do not commit .env.local to your git repository.

# Blockfrost API Project IDs
# Get these from https://blockfrost.io
#NEXT_PUBLIC_BLOCKFROST_PROJECT_ID_PREPROD="YOUR_BLOCKFROST_PREPROD_PROJECT_ID"
NEXT_PUBLIC_BLOCKFROST_PROJECT_ID_MAINNET="mainnetGh0oJFsbqjGDzAV5mdGUI8wv9zxQlkUk"

# Fallback Cardano Network (Preprod or Mainnet)
# This is used if no network is set in the user's browser cache.
NEXT_PUBLIC_CARDANO_NETWORK="Mainnet"

# Treasury Addresses for fee collection
# Make sure these are correct for the respective networks.
#NEXT_PUBLIC_TREASURY_ADDRESS_PREPROD="addr_test1vzzvtterv7flnrfvhwdygdm0clu0d6qcmr0u0vwmkc284echnvkqw"
NEXT_PUBLIC_TREASURY_ADDRESS_MAINNET="addr1q9zxp864enlra5tmgl6y32havq946njdxa7qd4gcxetj0seycr094w3r7jt7sp46j7t6gz8k6aljk40k46cjm5epvjzsj0dkpq"

# The following variables are derived from your Plutus contracts.
# Since your contract addresses are generated dynamically, you may not need to set these
# if the minting policy is also derived dynamically. If it's static, define it here.
# NEXT_PUBLIC_MINTING_POLICY_ID_PREPROD="YOUR_PREPROD_MINTING_POLICY_ID"
# NEXT_PUBLIC_MINTING_POLICY_ID_MAINNET="YOUR_MAINNET_MINTING_POLICY_ID"

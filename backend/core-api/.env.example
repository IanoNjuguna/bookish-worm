# Environment Variables
ADMIN_API_KEY=your-secret-key-change-this-in-production
API_SECRET_KEY=your-secret-key-change-this-in-production
PORT=3000
NODE_ENV=development
JWT_SECRET=replace-me-with-a-long-random-secret
API_SECRET_KEY=replace-me-with-a-long-random-secret

# Frontend origins allowed to call this API (comma-separated)
# Example: CORS_ORIGINS=https://app.yourdomain.com,https://www.yourdomain.com,http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Refresh cookie settings
# For app.yourdomain.com + api.yourdomain.com, use COOKIE_DOMAIN=.yourdomain.com
# If omitted, cookie will be host-only for api domain.
COOKIE_DOMAIN=
# Strict is safest when frontend and API are same-site. Use None only if truly cross-site.
COOKIE_SAMESITE=Strict

# Pinata IPFS
PINATA_JWT=
PINATA_API_SECRET=

# RPCs (Mainnet)
NEXT_PUBLIC_BASE_RPC_URL=

# Cardano network for backend on-chain checks (mainnet, preprod, preview)
CARDANO_NETWORK=mainnet

# Blockfrost key used by core-api server-side checks (preferred)
BLOCKFROST_PROJECT_ID=

# Optional frontend-style fallbacks if BLOCKFROST_PROJECT_ID is not set
NEXT_PUBLIC_BLOCKFROST_PROJECT_ID_MAINNET=
NEXT_PUBLIC_BLOCKFROST_PROJECT_ID_PREPROD=

# Turso Database
TURSO_URL=
TURSO_AUTH_TOKEN=
